<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <ui:VisualElement style="flex-grow: 1;">
        <ui:Vector3Field label="Dimensions" name="Dimensions" data-source-type="PoissonDiskSampling, Assembly-CSharp" data-source-path="_dimensions" binding-path="_dimensions"/>
        <ui:FloatField label="Distance" value="1" binding-path="_distance" name="Distance" data-source-type="PoissonDiskSampling, Assembly-CSharp" data-source-path=""/>
        <ui:IntegerField label="Attempts" value="30" binding-path="_attempts" name="Attempts" data-source-type="PoissonDiskSampling, Assembly-CSharp" data-source-path="_attempts"/>
        <ui:Toggle label="Show Points" binding-path="_showPoints" name="ShowPoints" data-source-type="PoissonDiskSampling, Assembly-CSharp" data-source-path="_showPoints"/>
        <ui:IntegerField label="Prop Count" value="30" binding-path="_propCount" name="PropCount" data-source-type="PoissonDiskSampling, Assembly-CSharp" data-source-path="_propCount"/>
        <uie:PropertyField binding-path="_propList" label="Props" focusable="false" name="PropList" data-source-type="PoissonDiskSampling, Assembly-CSharp" data-source-path="_propList"/>
        <ui:VisualElement name="Buttons" style="flex-grow: 1; align-items: stretch; justify-content: center; flex-direction: row;">
            <ui:Button data-source-type="PoissonDiskSampling, Assembly-CSharp" text="Generate Samples" name="GenerateSampleButtons"/>
            <ui:Button data-source-type="PoissonDiskSampling, Assembly-CSharp" text="Clear Samples" name="ClearSamples"/>
        </ui:VisualElement>
        <ui:VisualElement name="Buttons" style="flex-grow: 1; align-items: stretch; justify-content: center; flex-direction: row;"/>
    </ui:VisualElement>
</ui:UXML>
